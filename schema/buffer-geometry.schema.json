{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://seoulgaok.com/sbim/buffer-geometry.schema.json",
  "title": "BufferGeometryData",
  "description": "Three.js BufferGeometry serialized as JSON. Compatible with THREE.BufferGeometryLoader.",
  "type": "object",
  "required": ["metadata", "uuid", "type", "data"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version", "type", "generator"],
      "properties": {
        "version": { "type": "number", "examples": [4.5] },
        "type": { "type": "string", "examples": ["BufferGeometry"] },
        "generator": { "type": "string", "examples": ["RhinoPython", "shapely"] }
      }
    },
    "uuid": { "type": "string" },
    "type": { "type": "string", "const": "BufferGeometry" },
    "data": {
      "type": "object",
      "required": ["attributes", "index"],
      "properties": {
        "attributes": {
          "type": "object",
          "required": ["position", "normal"],
          "properties": {
            "position": { "$ref": "#/$defs/BufferAttributeData" },
            "normal": { "$ref": "#/$defs/BufferAttributeData" },
            "uv": {
              "oneOf": [
                { "$ref": "#/$defs/BufferAttributeData" },
                { "type": "null" }
              ]
            }
          }
        },
        "index": {
          "type": "object",
          "required": ["type", "array"],
          "properties": {
            "type": { "type": "string", "examples": ["Uint32Array", "Uint16Array"] },
            "array": {
              "type": "array",
              "items": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "BufferAttributeData": {
      "type": "object",
      "required": ["itemSize", "type", "array"],
      "properties": {
        "itemSize": { "type": "integer", "enum": [1, 2, 3, 4] },
        "type": { "type": "string", "examples": ["Float32Array"] },
        "array": {
          "type": "array",
          "items": { "type": "number" }
        }
      }
    }
  }
}
