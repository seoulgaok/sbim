{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://seoulgaok.com/sbim/scheme.schema.json",
  "title": "Scheme",
  "description": "서울가옥 BIM scheme — 다세대주택 LoD 100~200 building scheme 단일 진실. volume_suggestion이 출력하고, DeerFlow가 편집하며, BuildingMeshVisualizer가 렌더링한다.",
  "type": "object",
  "required": ["data", "floor_plans", "unit_ids"],
  "properties": {
    "data": { "$ref": "#/$defs/SchemeData" },
    "floor_plans": {
      "type": "array",
      "items": { "$ref": "#/$defs/FloorPlan" }
    },
    "unit_ids": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "SchemeData": {
      "type": "object",
      "description": "프로젝트 레벨 메타데이터",
      "required": ["lot_area", "build_area", "far", "bcr", "pnu"],
      "properties": {
        "lot_area": { "type": "number", "description": "대지면적 (㎡)" },
        "build_area": { "type": "number", "description": "건축면적 (㎡)" },
        "far": { "type": "number", "description": "용적률" },
        "bcr": { "type": "number", "description": "건폐율" },
        "pnu": { "type": ["number", "string"], "description": "부동산고유번호" }
      }
    },
    "FloorPlan": {
      "type": "object",
      "required": ["data", "geom"],
      "properties": {
        "data": { "$ref": "#/$defs/FloorData" },
        "geom": { "$ref": "#/$defs/FloorGeometry" }
      }
    },
    "FloorData": {
      "type": "object",
      "required": ["floor_id", "floor_area", "floor_height", "floor_bottom_height"],
      "properties": {
        "floor_id": {
          "type": "integer",
          "description": "층 ID. -1=지하1, 0=주차층/필로티, 1+=일반층"
        },
        "floor_area": { "type": "number", "description": "해당 층 면적 (㎡)" },
        "floor_height": { "type": "number", "description": "층 높이 (m)" },
        "floor_bottom_height": { "type": "number", "description": "층 바닥 높이 (m)" }
      }
    },
    "FloorGeometry": {
      "type": "object",
      "required": ["walls", "floors"],
      "properties": {
        "walls": {
          "type": "array",
          "description": "벽 mesh 그룹 배열. 각 그룹은 같은 머터리얼/스타일을 공유.",
          "items": {
            "type": "array",
            "items": { "$ref": "buffer-geometry.schema.json" }
          }
        },
        "floors": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "$ref": "buffer-geometry.schema.json" }
          }
        },
        "roof": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "$ref": "buffer-geometry.schema.json" }
          }
        }
      }
    }
  }
}
